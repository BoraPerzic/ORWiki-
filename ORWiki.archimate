    <element xsi:type="archimate:CompositionRelationship" id="id-comp-plan-4" source="id-grp-plan" target="id-721"><property key="Source" value="ORWiki"/></element>
    <element xsi:type="archimate:CompositionRelationship" id="id-comp-plan-5" source="id-grp-plan" target="id-461"><property key="Source" value="ORWiki"/></element>
    <element xsi:type="archimate:CompositionRelationship" id="id-comp-plan-6" source="id-grp-plan" target="id-451"><property key="Source" value="ORWiki"/></element>
    <element xsi:type="archimate:CompositionRelationship" id="id-comp-plan-7" source="id-grp-plan" target="id-471"><property key="Source" value="ORWiki"/></element>
