    <element xsi:type="archimate:CompositionRelationship" id="id-comp-source-2" source="id-grp-source" target="id-741"><property key="Source" value="ORWiki"/></element>
    <element xsi:type="archimate:CompositionRelationship" id="id-comp-source-3" source="id-grp-source" target="id-751"><property key="Source" value="ORWiki"/></element>
    <element xsi:type="archimate:CompositionRelationship" id="id-comp-source-4" source="id-grp-source" target="id-761"><property key="Source" value="ORWiki"/></element>
    <element xsi:type="archimate:CompositionRelationship" id="id-comp-source-5" source="id-grp-source" target="id-771"><property key="Source" value="ORWiki"/></element>
